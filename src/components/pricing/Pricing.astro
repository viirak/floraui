---
// Define props interface for component customization
interface PricingPlan {
  id: string;
  name: string;
  description: string;
  monthlyPrice: number;
  annualPrice: number;
  popular?: boolean;
  features: string[];
}

interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  defaultFrequency?: 'monthly' | 'annually';
  plans?: PricingPlan[];
}

// Default values for props
const {
  title = "Pricing",
  subtitle = "Pricing that grows with you",
  description = "Choose an affordable plan that's packed with the best features for engaging your audience, creating customer loyalty, and driving sales.",
  defaultFrequency = "monthly",
  plans = [
    {
      id: "freelancer",
      name: "Freelancer",
      description: "The essentials to provide your best work for clients.",
      monthlyPrice: 19,
      annualPrice: 190,
      features: [
        "5 products",
        "Up to 1,000 subscribers",
        "Basic analytics",
        "48-hour support response time"
      ]
    },
    {
      id: "startup",
      name: "Startup",
      description: "A plan that scales with your rapidly growing business.",
      monthlyPrice: 29,
      annualPrice: 290,
      popular: true,
      features: [
        "25 products",
        "Up to 10,000 subscribers",
        "Advanced analytics",
        "24-hour support response time",
        "Marketing automations"
      ]
    },
    {
      id: "enterprise",
      name: "Enterprise",
      description: "Dedicated support and infrastructure for your company.",
      monthlyPrice: 59,
      annualPrice: 590,
      features: [
        "Unlimited products",
        "Unlimited subscribers",
        "Advanced analytics",
        "1-hour, dedicated support response time",
        "Marketing automations",
        "Custom reporting tools"
      ]
    }
  ]
} = Astro.props;
---

<div class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-base/7 font-semibold text-indigo-600">{title}</h2>
      <p class="mt-2 text-5xl font-semibold tracking-tight text-balance text-gray-900 sm:text-6xl">{subtitle}</p>
    </div>
    <p class="mx-auto mt-6 max-w-2xl text-center text-lg font-medium text-pretty text-gray-600 sm:text-xl/8">{description}</p>
    <div class="mt-16 flex justify-center">
      <fieldset aria-label="Payment frequency">
        <div class="grid grid-cols-2 gap-x-1 rounded-full p-1 text-center text-xs/5 font-semibold ring-1 ring-gray-200 ring-inset">
          <label class="frequency-toggle cursor-pointer rounded-full px-2.5 py-1" data-active={defaultFrequency === "monthly"}>
            <input type="radio" name="frequency" value="monthly" class="sr-only" checked={defaultFrequency === "monthly"}>
            <span>Monthly</span>
          </label>
          <label class="frequency-toggle cursor-pointer rounded-full px-2.5 py-1" data-active={defaultFrequency === "annually"}>
            <input type="radio" name="frequency" value="annually" class="sr-only" checked={defaultFrequency === "annually"}>
            <span>Annually</span>
          </label>
        </div>
      </fieldset>
    </div>
    <div class="isolate mx-auto mt-10 grid max-w-md grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      {plans.map((plan) => (
        <div class={`rounded-3xl p-8 ${plan.popular ? 'ring-2 ring-indigo-600' : 'ring-1 ring-gray-200'} xl:p-10`}>
          <div class="flex items-center justify-between gap-x-4">
            <h3 id={`tier-${plan.id}`} class={`text-lg/8 font-semibold ${plan.popular ? 'text-indigo-600' : 'text-gray-900'}`}>{plan.name}</h3>
            {plan.popular && <p class="rounded-full bg-indigo-600/10 px-2.5 py-1 text-xs/5 font-semibold text-indigo-600">Most popular</p>}
          </div>
          <p class="mt-4 text-sm/6 text-gray-600">{plan.description}</p>
          <p class="mt-6 flex items-baseline gap-x-1">
            <span class="text-4xl font-semibold tracking-tight text-gray-900 price-amount" 
                  data-monthly={plan.monthlyPrice} 
                  data-annually={plan.annualPrice}>
              ${defaultFrequency === "monthly" ? plan.monthlyPrice : plan.annualPrice}
            </span>
            <span class="text-sm/6 font-semibold text-gray-600 price-period">
              /{defaultFrequency === "monthly" ? "month" : "year"}
            </span>
          </p>
          <a href="#" aria-describedby={`tier-${plan.id}`} 
             class={`mt-6 block rounded-md ${plan.popular 
               ? 'bg-indigo-600 px-3 py-2 text-center text-sm/6 font-semibold text-white shadow-xs hover:bg-indigo-500' 
               : 'px-3 py-2 text-center text-sm/6 font-semibold text-indigo-600 ring-1 ring-indigo-200 ring-inset hover:ring-indigo-300'} 
               focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600`}>
            Buy plan
          </a>
          <ul role="list" class="mt-8 space-y-3 text-sm/6 text-gray-600 xl:mt-10">
            {plan.features.map((feature) => (
              <li class="flex gap-x-3">
                <svg class="h-6 w-5 flex-none text-indigo-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  // Handle price toggle functionality
  document.addEventListener('DOMContentLoaded', () => {
    const toggles = document.querySelectorAll('input[name="frequency"]');
    const priceAmounts = document.querySelectorAll('.price-amount');
    const pricePeriods = document.querySelectorAll('.price-period');
    const frequencyLabels = document.querySelectorAll('.frequency-toggle');

    toggles.forEach(toggle => {
      toggle.addEventListener('change', (e) => {
        const frequency = e.target.value;
        
        // Update price amounts
        priceAmounts.forEach(price => {
          const monthlyPrice = price.getAttribute('data-monthly');
          const annualPrice = price.getAttribute('data-annually');
          price.textContent = `$${frequency === 'monthly' ? monthlyPrice : annualPrice}`;
        });
        
        // Update price periods
        pricePeriods.forEach(period => {
          period.textContent = `/${frequency === 'monthly' ? 'month' : 'year'}`;
        });
        
        // Update toggle UI
        frequencyLabels.forEach(label => {
          const isActive = label.querySelector('input').value === frequency;
          label.classList.toggle('bg-indigo-600', isActive);
          label.classList.toggle('text-white', isActive);
          label.classList.toggle('text-gray-500', !isActive);
          label.setAttribute('data-active', isActive.toString());
        });
      });
    });

    // Initialize the toggle states based on default selection
    frequencyLabels.forEach(label => {
      const isActive = label.getAttribute('data-active') === 'true';
      label.classList.toggle('bg-indigo-600', isActive);
      label.classList.toggle('text-white', isActive);
      label.classList.toggle('text-gray-500', !isActive);
    });
  });
</script>
