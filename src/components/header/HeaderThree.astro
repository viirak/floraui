---
// Define the props interface
interface Props {
  logoSrc?: string;
  logoAlt?: string;
  companyName?: string;
  menuItems?: {
    label: string;
    href: string;
    dropdown?: boolean;
    items?: {
      title: string;
      description: string;
      href: string;
      icon: string;
    }[];
  }[];
  ctaText?: string;
  ctaHref?: string;
}

// Set default values for props
const {
  logoSrc = "https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=600",
  logoAlt = "Your Company",
  companyName = "Your Company",
  menuItems = [
    {
      label: "Product",
      href: "#",
      dropdown: true,
      items: [
        {
          title: "Analytics",
          description: "Get a better understanding where your traffic is coming from",
          href: "#",
          icon: "M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z"
        },
        {
          title: "Engagement",
          description: "Speak directly to your customers with our engagement tool",
          href: "#",
          icon: "M15.042 21.672 13.684 16.6m0 0-2.51 2.225.569-9.47 5.227 7.917-3.286-.672ZM12 2.25V4.5m5.834.166-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243-1.59-1.59"
        },
        {
          title: "Security",
          description: "Your customers' data will be safe and secure",
          href: "#",
          icon: "M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"
        },
        {
          title: "Integrations",
          description: "Your customers' data will be safe and secure",
          href: "#",
          icon: "M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"
        }
      ]
    },
    { label: "Features", href: "/feature" },
    { label: "Marketplace", href: "/marketplace" },
    { label: "Company", href: "about" }
  ],
  ctaText = "Find Us",
  ctaHref = "contact"
} = Astro.props;
---

<header class="relative isolate z-10 border-b border-gray-900/10 bg-white">
  <nav class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8" aria-label="Global">
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5 transition duration-200 hover:opacity-80">
        <span class="sr-only">{companyName}</span>
        <img class="h-8 w-auto" src={logoSrc} alt={logoAlt}>
      </a>
    </div>
    <div class="flex lg:hidden">
      <button type="button" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700 transition duration-200 hover:bg-gray-100 active:scale-95" id="mobile-menu-button">
        <span class="sr-only">Open main menu</span>
        <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:gap-x-12">
      {menuItems.map(item => (
        item.dropdown ? (
          <div id="product-menu-container">
            <button 
              type="button" 
              class="flex items-center gap-x-1 text-sm/6 font-semibold text-gray-900 transition duration-200 hover:text-indigo-600 active:scale-95" 
              aria-expanded="false"
              id="product-menu-button"
            >
              {item.label}
              <svg class="size-5 flex-none text-gray-400 transition-transform duration-200 group-hover:text-indigo-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </button>

            <div class="absolute inset-x-0 top-0 -z-10 bg-white pt-14 shadow-lg ring-1 ring-gray-900/5 hidden transition-all duration-300 ease-in-out" id="product-dropdown">
              <div class="mx-auto grid max-w-7xl grid-cols-4 gap-x-4 px-6 py-10 lg:px-8 xl:gap-x-8">
                {item.items?.map(subItem => (
                  <div class="group relative rounded-lg p-6 text-sm/6 transition duration-200 hover:bg-gray-50">
                    <div class="flex size-11 items-center justify-center rounded-lg bg-gray-50 transition duration-200 group-hover:bg-white group-hover:shadow-md">
                      <svg class="size-6 text-gray-600 transition duration-200 group-hover:text-indigo-600 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
                        <path stroke-linecap="round" stroke-linejoin="round" d={subItem.icon} />
                      </svg>
                    </div>
                    <a href={subItem.href} class="mt-6 block font-semibold text-gray-900 transition duration-200 group-hover:text-indigo-600">
                      {subItem.title}
                      <span class="absolute inset-0"></span>
                    </a>
                    <p class="mt-1 text-gray-600 transition duration-200 group-hover:text-gray-900">{subItem.description}</p>
                  </div>
                ))}
              </div>
              
              <div class="bg-gray-50">
                <div class="mx-auto max-w-7xl px-6 lg:px-8">
                  <div class="grid grid-cols-3 divide-x divide-gray-900/5 border-x border-gray-900/5">
                    <a href="/demo" class="flex items-center justify-center gap-x-2.5 p-3 text-sm/6 font-semibold text-gray-900 transition duration-200 hover:bg-gray-100 hover:text-indigo-600 active:bg-gray-200">
                      <svg class="size-5 flex-none text-gray-400 transition duration-200 group-hover:text-indigo-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                        <path fill-rule="evenodd" d="M2 10a8 8 0 1 1 16 0 8 8 0 0 1-16 0Zm6.39-2.908a.75.75 0 0 1 .766.027l3.5 2.25a.75.75 0 0 1 0 1.262l-3.5 2.25A.75.75 0 0 1 8 12.25v-4.5a.75.75 0 0 1 .39-.658Z" clip-rule="evenodd" />
                      </svg>
                      Watch demo
                    </a>
                    <a href="#" class="flex items-center justify-center gap-x-2.5 p-3 text-sm/6 font-semibold text-gray-900 transition duration-200 hover:bg-gray-100 hover:text-indigo-600 active:bg-gray-200">
                      <svg class="size-5 flex-none text-gray-400 transition duration-200 group-hover:text-indigo-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                        <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" clip-rule="evenodd" />
                      </svg>
                      Contact sales
                    </a>
                    <a href="#" class="flex items-center justify-center gap-x-2.5 p-3 text-sm/6 font-semibold text-gray-900 transition duration-200 hover:bg-gray-100 hover:text-indigo-600 active:bg-gray-200">
                      <svg class="size-5 flex-none text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                        <path fill-rule="evenodd" d="M2.5 3A1.5 1.5 0 0 0 1 4.5v4A1.5 1.5 0 0 0 2.5 10h6A1.5 1.5 0 0 0 10 8.5v-4A1.5 1.5 0 0 0 8.5 3h-6Zm11 2A1.5 1.5 0 0 0 12 6.5v7a1.5 1.5 0 0 0 1.5 1.5h4a1.5 1.5 0 0 0 1.5-1.5v-7A1.5 1.5 0 0 0 17.5 5h-4Zm-10 7A1.5 1.5 0 0 0 2 13.5v2A1.5 1.5 0 0 0 3.5 17h6a1.5 1.5 0 0 0 1.5-1.5v-2A1.5 1.5 0 0 0 9.5 12h-6Z" clip-rule="evenodd" />
                      </svg>
                      View all products
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ) : (
          <a href={item.href} class="text-sm/6 font-semibold text-gray-900 relative transition duration-200 hover:text-indigo-600 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-indigo-600 after:transition-all after:duration-300 hover:after:w-full">{item.label}</a>
        )
      ))}
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end">
      <a href={ctaHref} class="text-sm/6 font-semibold text-gray-900 transition duration-200 hover:text-indigo-600 group">
        {ctaText} 
        <span aria-hidden="true" class="inline-block transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>
  </nav>
  
  <!-- Mobile menu, show/hide based on menu open state. -->
  <div class="lg:hidden hidden" role="dialog" aria-modal="true" id="mobile-menu">
    <div class="fixed inset-0 z-10 bg-gray-900/20 backdrop-blur-sm transition-opacity duration-300 opacity-0"></div>
    <div class="fixed inset-y-0 right-0 z-10 w-full overflow-y-auto bg-white px-6 py-6 shadow-xl translate-x-full sm:max-w-sm sm:ring-1 sm:ring-gray-900/10 transition-transform duration-300 ease-in-out">
      <div class="flex items-center justify-between">
        <a href="#" class="-m-1.5 p-1.5 transition duration-200 hover:opacity-80">
          <span class="sr-only">{companyName}</span>
          <img class="h-8 w-auto" src={logoSrc} alt={logoAlt}>
        </a>
        <button type="button" class="-m-2.5 rounded-md p-2.5 text-gray-700 transition duration-200 hover:bg-gray-100 active:scale-95" id="close-mobile-menu">
          <span class="sr-only">Close menu</span>
          <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <div class="mt-6 flow-root">
        <div class="-my-6 divide-y divide-gray-500/10">
          <div class="space-y-2 py-6">
            {menuItems.map((item, index) => (
              item.dropdown ? (
                <div class="-mx-3">
                  <button 
                    type="button" 
                    class="flex w-full items-center justify-between rounded-lg py-2 pr-3.5 pl-3 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 transition duration-200 active:bg-gray-100 hover:text-indigo-600" 
                    aria-controls={`disclosure-${index}`}
                    aria-expanded="false"
                    id={`mobile-menu-button-${index}`}
                  >
                    {item.label}
                    <svg class="size-5 flex-none mobile-dropdown-icon transition-transform duration-300" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                      <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                    </svg>
                  </button>
                  
                  <!-- Mobile product submenu -->
                  <div class="mt-2 space-y-2 hidden overflow-hidden transition-all duration-300 ease-in-out" id={`disclosure-${index}`} style="max-height: 0; opacity: 0;">
                    {item.items?.map(subItem => (
                      <a href={subItem.href} class="block rounded-lg py-2 pr-3 pl-6 text-sm/7 font-semibold text-gray-900 transition duration-200 hover:bg-gray-50 hover:text-indigo-600 active:bg-gray-100">{subItem.title}</a>
                    ))}
                  </div>
                </div>
              ) : (
                <a href={item.href} class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-gray-900 transition duration-200 hover:bg-gray-50 hover:text-indigo-600 active:bg-gray-100">{item.label}</a>
              )
            ))}
          </div>
          <div class="py-6">
            <a href={ctaHref} class="-mx-3 block rounded-lg px-3 py-2.5 text-base/7 font-semibold text-gray-900 transition duration-200 hover:bg-gray-50 hover:text-indigo-600 active:bg-gray-100 group">
              {ctaText}
              <span aria-hidden="true" class="ml-1 inline-block transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Desktop dropdown toggle
  const productMenuButton = document.getElementById('product-menu-button');
  const productDropdown = document.getElementById('product-dropdown');

  if (productMenuButton && productDropdown) {
    productMenuButton.addEventListener('click', () => {
      const expanded = productMenuButton.getAttribute('aria-expanded') === 'true';
      productMenuButton.setAttribute('aria-expanded', String(!expanded));
      
      if (expanded) {
        // Closing the dropdown
        productDropdown.classList.add('opacity-0', '-translate-y-1');
        productDropdown.classList.remove('opacity-100', 'translate-y-0');
        
        // Add a small delay before hiding completely to allow for animation
        setTimeout(() => {
          productDropdown.classList.add('hidden');
        }, 300);
      } else {
        // Opening the dropdown
        productDropdown.classList.remove('hidden');
        
        // Small delay to ensure the transition works after removing hidden
        setTimeout(() => {
          productDropdown.classList.add('opacity-100', 'translate-y-0');
          productDropdown.classList.remove('opacity-0', '-translate-y-1');
        }, 10);
      }
    });
  }

  // Mobile menu toggle with animations
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const closeMobileMenu = document.getElementById('close-mobile-menu');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuContent = mobileMenu?.querySelector('.fixed.inset-y-0.right-0');
  const backdrop = mobileMenu?.querySelector('.fixed.inset-0');

  if (mobileMenuButton && mobileMenu && closeMobileMenu && mobileMenuContent && backdrop) {
    // Initialize with proper classes
    mobileMenuContent.classList.add('translate-x-full');
    backdrop.classList.add('opacity-0');
    
    mobileMenuButton.addEventListener('click', () => {
      // Show the menu container first
      mobileMenu.classList.remove('hidden');
      
      // Give the browser a moment to process the display change
      requestAnimationFrame(() => {
        // Now animate in the backdrop
        backdrop.classList.remove('opacity-0');
        backdrop.classList.add('opacity-100');
        
        // And slide in the menu
        mobileMenuContent.classList.remove('translate-x-full');
        mobileMenuContent.classList.add('translate-x-0');
      });
    });

    closeMobileMenu.addEventListener('click', () => {
      // First animate out
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      mobileMenuContent.classList.remove('translate-x-0');
      mobileMenuContent.classList.add('translate-x-full');
      
      // Then hide after animation completes
      setTimeout(() => {
        mobileMenu.classList.add('hidden');
      }, 300);
    });
    
    // Close when clicking on backdrop
    backdrop.addEventListener('click', () => {
      closeMobileMenu.click();
    });
  }

  // Mobile dropdown toggle with enhanced animation
  document.querySelectorAll('[id^="mobile-menu-button-"]').forEach((button, index) => {
    const dropdownId = `disclosure-${index}`;
    const dropdown = document.getElementById(dropdownId);
    const icon = button.querySelector('.mobile-dropdown-icon');
    
    if (button && dropdown && icon) {
      button.addEventListener('click', () => {
        const expanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!expanded));
        
        if (expanded) {
          // Collapse animation
          dropdown.style.maxHeight = '0px';
          dropdown.style.opacity = '0';
          
          setTimeout(() => {
            dropdown.classList.add('hidden');
            icon.classList.remove('rotate-180');
          }, 200);
        } else {
          // Expand animation
          dropdown.classList.remove('hidden');
          
          requestAnimationFrame(() => {
            const height = dropdown.scrollHeight;
            dropdown.style.maxHeight = height + 'px';
            dropdown.style.opacity = '1';
            icon.classList.add('rotate-180');
          });
        }
      });
    }
  });
</script>

<style>
  /* Add smooth transitions for dropdown menus */
  #product-dropdown {
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  
  #product-dropdown.opacity-100 {
    opacity: 1;
    transform: translateY(0);
  }
  
  /* Mobile-specific styles */
  @media (max-width: 1023px) {
    .fixed.inset-y-0.right-0 {
      width: 100%;
      max-width: 24rem;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }
    
    /* Different screen sizes */
    @media (max-width: 639px) {
      .fixed.inset-y-0.right-0 {
        max-width: 100%;
      }
    }
  }
  
  /* Handle mobile nested menu transitions */
  [id^="disclosure-"] {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }
</style>
